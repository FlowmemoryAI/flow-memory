# Flow Memory Compute Market live production-planning environment template.
# Copy to a secret-managed environment file outside git and fill every CHANGEME value.
#
# Render provisioning values are shell exports consumed by scripts/deploy_compute_market_render_level1.py.
# Do not sync RENDER_API_KEY into the running service environment.
RENDER_API_KEY=CHANGEME-render-api-key
RENDER_OWNER_ID=CHANGEME-render-owner-or-workspace-id
RENDER_KEYVALUE_IP_ALLOWLIST=CHANGEME-public-egress-cidr
RENDER_POSTGRES_PLAN=basic_256mb
RENDER_KEYVALUE_PLAN=starter
RENDER_SERVICE_PLAN=starter
RENDER_SERVICE_NAME=flow-memory-compute-market-api
RENDER_BRANCH=main
RENDER_REPO_URL=CHANGEME-render-connected-repository-url
RENDER_ENABLE_DISK=false
RENDER_REGION=oregon

FLOW_MEMORY_API_HOST=0.0.0.0
FLOW_MEMORY_API_PORT=8765
FLOW_MEMORY_PUBLIC_API_URL=https://api.yourdomain.com
FLOW_MEMORY_API_KEY=CHANGEME-high-entropy-api-key
FLOW_MEMORY_API_KEY_SCOPES=api:read api:write api:admin api:audit compute:read compute:plan compute:execute compute:admin compute:audit compute:provider-admin compute:policy-admin compute:billing compute:settlement-admin inference:read inference:plan inference:proxy inference:buy inference:sell inference:admin inference:audit
FLOW_MEMORY_API_REQUIRE_SCOPES=true
# Optional API gateway/OIDC bridge: set only when a trusted gateway mints HS256 bearer JWTs.
FLOW_MEMORY_API_JWT_HS256_SECRET=
FLOW_MEMORY_API_JWT_ISSUER=
FLOW_MEMORY_API_JWT_AUDIENCE=
FLOW_MEMORY_API_JWT_LEEWAY_SECONDS=60
FLOW_MEMORY_API_RATE_LIMIT=120
FLOW_MEMORY_API_RATE_LIMIT_WINDOW_SECONDS=60
FLOW_MEMORY_API_MAX_BODY_BYTES=1048576
FLOW_MEMORY_API_ENABLE_NONCE_CHECK=true
FLOW_MEMORY_API_MAX_REQUEST_AGE_SECONDS=300
FLOW_MEMORY_API_NONCE_REPLAY_BACKEND=redis
FLOW_MEMORY_API_NONCE_REDIS_PREFIX=flow-memory:api
FLOW_MEMORY_API_NONCE_FAIL_CLOSED=true
FLOW_MEMORY_API_NONCE_REQUIRE_TLS=true
FLOW_MEMORY_API_NONCE_VERIFY_TLS=true

FLOW_MEMORY_COMPUTE_MARKET_ENABLED=true
FLOW_MEMORY_COMPUTE_MARKET_MODE=production_planning
FLOW_MEMORY_COMPUTE_STORAGE_BACKEND=postgres
FLOW_MEMORY_POSTGRES_PASSWORD=CHANGEME-compose-fallback-postgres-password
FLOW_MEMORY_COMPUTE_DATABASE_URL=postgresql://flow_memory:CHANGEME-managed-postgres-password@CHANGEME-managed-postgres-host:5432/flow_memory
FLOW_MEMORY_COMPUTE_POSTGRES_SSL_MODE=require
FLOW_MEMORY_COMPUTE_STORAGE_POOL_SIZE=4
FLOW_MEMORY_COMPUTE_STORAGE_MAX_OVERFLOW=4
FLOW_MEMORY_COMPUTE_STORAGE_TIMEOUT_MS=5000
FLOW_MEMORY_COMPUTE_STORAGE_STATEMENT_TIMEOUT_MS=5000
FLOW_MEMORY_COMPUTE_MIGRATIONS_ENABLED=true
FLOW_MEMORY_COMPUTE_MIGRATIONS_AUTO_RUN=true
FLOW_MEMORY_COMPUTE_REQUIRE_MANAGED_SQL_IN_PRODUCTION=true
FLOW_MEMORY_COMPUTE_REQUIRE_MANAGED_REDIS_IN_PRODUCTION=true
# Public Level 1 requires externally stored operational evidence for managed Postgres.
FLOW_MEMORY_COMPUTE_POSTGRES_BACKUP_POLICY_URI=https://CHANGEME-ops.example.com/flow-memory/postgres-backup-policy
FLOW_MEMORY_COMPUTE_POSTGRES_RESTORE_DRILL_URI=https://CHANGEME-ops.example.com/flow-memory/postgres-restore-drill
FLOW_MEMORY_COMPUTE_POSTGRES_BLUE_GREEN_REHEARSAL_URI=https://CHANGEME-ops.example.com/flow-memory/postgres-blue-green-rehearsal

FLOW_MEMORY_COMPUTE_RATE_LIMITS_ENABLED=true
FLOW_MEMORY_COMPUTE_RATE_LIMIT_BACKEND=redis
FLOW_MEMORY_COMPUTE_CIRCUIT_BREAKER_BACKEND=redis
# Render API deployment reads RENDER_KEYVALUE_IP_ALLOWLIST from the shell and refuses to create
# a production Redis Key Value instance without external rediss:// allowlisted CIDRs.
# Do not use Render's redis:// internal connection string for public production mode.
FLOW_MEMORY_COMPUTE_REDIS_URL=rediss://CHANGEME-managed-redis-host:6379/0
FLOW_MEMORY_COMPUTE_REDIS_PREFIX=flow-memory:compute-market
FLOW_MEMORY_COMPUTE_RATE_LIMIT_ENABLED=true
FLOW_MEMORY_COMPUTE_CIRCUIT_BREAKER_ENABLED=true
FLOW_MEMORY_COMPUTE_RATE_LIMIT_FAIL_CLOSED=true
FLOW_MEMORY_COMPUTE_CIRCUIT_BREAKER_FAIL_CLOSED=true

FLOW_MEMORY_COMPUTE_DRY_RUN_REQUIRED=true
FLOW_MEMORY_COMPUTE_LIVE_SETTLEMENT_ENABLED=false
FLOW_MEMORY_COMPUTE_BROADCAST_ENABLED=false
FLOW_MEMORY_COMPUTE_PRIVATE_KEY_INPUTS_ALLOWED=false
FLOW_MEMORY_COMPUTE_AUDIT_REQUIRED=true
FLOW_MEMORY_COMPUTE_METRICS_ENABLED=true
FLOW_MEMORY_COMPUTE_TRACING_ENABLED=true

# Public Level 1 deployment requires real HTTPS observability sinks; keep these enabled.
FLOW_MEMORY_COMPUTE_ALERT_ROUTING_ENABLED=true
FLOW_MEMORY_COMPUTE_ALERT_WEBHOOK_URL=https://CHANGEME-alerts.example.com/flow-memory
FLOW_MEMORY_COMPUTE_ALERT_WEBHOOK_SECRET=CHANGEME-alert-webhook-shared-secret
FLOW_MEMORY_COMPUTE_ALERT_WEBHOOK_TIMEOUT_MS=2000
FLOW_MEMORY_COMPUTE_ERROR_TRACKING_ENABLED=true
FLOW_MEMORY_COMPUTE_ERROR_TRACKING_WEBHOOK_URL=https://CHANGEME-errors.example.com/flow-memory
FLOW_MEMORY_COMPUTE_ERROR_TRACKING_WEBHOOK_SECRET=CHANGEME-error-webhook-shared-secret
FLOW_MEMORY_COMPUTE_ERROR_TRACKING_TIMEOUT_MS=2000
FLOW_MEMORY_COMPUTE_TELEMETRY_EXPORT_ENABLED=true
FLOW_MEMORY_COMPUTE_OTLP_ENDPOINT_URL=https://CHANGEME-otel.example.com/v1/traces
FLOW_MEMORY_COMPUTE_OTLP_HEADERS=authorization: Bearer CHANGEME-otlp-token
FLOW_MEMORY_COMPUTE_OTLP_TIMEOUT_MS=5000

FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_REQUIRED=true
FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_URI=s3://CHANGEME-audit-object-lock-bucket/compute-market
FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_OBJECT_LOCK_MODE=COMPLIANCE
FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_RETENTION_DAYS=365
FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_IMMUTABLE_REQUIRED=true
FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_S3_REGION=us-east-1
# Leave empty for AWS S3; set for S3-compatible stores such as MinIO or Ceph.
FLOW_MEMORY_COMPUTE_AUDIT_EXPORT_S3_ENDPOINT_URL=
FLOW_MEMORY_COMPUTE_AUDIT_CHECKPOINT_INTERVAL_SECONDS=86400
FLOW_MEMORY_COMPUTE_PROVIDER_CONTRACTS_REQUIRED=false
FLOW_MEMORY_COMPUTE_PROVIDER_CONTRACTS_VERIFIED=false
FLOW_MEMORY_COMPUTE_EXTERNAL_QUOTES_ENABLED=false
FLOW_MEMORY_COMPUTE_EXTERNAL_EXECUTION_ENABLED=false
FLOW_MEMORY_COMPUTE_EXTERNAL_PROVIDER_ALLOWLIST=
# Optional until external providers are enabled; must be explicit provider source IP/CIDR values.
FLOW_MEMORY_COMPUTE_PROVIDER_CALLBACK_IP_ALLOWLIST=
FLOW_MEMORY_COMPUTE_ECONOMIC_MEMORY_WRITES_ENABLED=true
FLOW_MEMORY_COMPUTE_ADMIN_MUTATIONS_ENABLED=true
# External billing stays disabled for Level 1. Populate Stripe secrets only after the
# prepaid-credit billing gate is enabled and webhook signature verification is tested.
FLOW_MEMORY_BILLING_STRIPE_CHECKOUT_ENABLED=false
FLOW_MEMORY_BILLING_STRIPE_SECRET_KEY=
FLOW_MEMORY_BILLING_STRIPE_SUCCESS_URL=
FLOW_MEMORY_BILLING_STRIPE_CANCEL_URL=
FLOW_MEMORY_BILLING_STRIPE_CHECKOUT_TIMEOUT_MS=5000
FLOW_MEMORY_BILLING_STRIPE_API_BASE_URL=https://api.stripe.com
FLOW_MEMORY_BILLING_STRIPE_PRODUCT_NAME=Flow Memory compute credits
FLOW_MEMORY_BILLING_STRIPE_WEBHOOK_SECRET=
FLOW_MEMORY_BILLING_STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# Enable these only after a provider contract fixture passes validation and a sandbox quote endpoint succeeds.
FLOW_MEMORY_COMPUTE_PROVIDER_TIMEOUT_MS=2000
FLOW_MEMORY_COMPUTE_GLOBAL_PLANNING_TIMEOUT_MS=10000
FLOW_MEMORY_COMPUTE_MAX_CANDIDATE_ROUTES=64
FLOW_MEMORY_COMPUTE_MAX_QUOTE_CACHE_ENTRIES=10000

# Live settlement remains disabled. Leave these empty for Level 1.
# Populate only after a reviewed settlement phase enables FLOW_MEMORY_COMPUTE_LIVE_SETTLEMENT_ENABLED=true.
FLOW_MEMORY_COMPUTE_SETTLEMENT_ENVIRONMENT=
FLOW_MEMORY_COMPUTE_SETTLEMENT_SECURITY_REVIEW_ID=
