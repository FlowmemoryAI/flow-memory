# Live Agent Operations market observer.
# Compute Market behavior is simulated locally with dry-run payment metadata.
agent LiveOpsMarketObserver {
  identity: "did:flow:example:live-ops-market-observer"
  goal: "simulate a local compute route and explain budget and policy constraints"
  autonomy: "supervised"
  tool: "respond"
  capability: "compute_market"
  capability: "neural_advisory"

  compute {
    enabled: true
    model: "small-general"
    expected_input_tokens: 1000
    expected_output_tokens: 400
    max_total_cost: 0.01
    max_quote: 0.01
    strategy: "cheapest_eligible"
    dry_run_required: true
    payment_rail: "local_credits"
  }

  neural {
    enabled: true
    backend: "tiny_torch"
    live_mode: true
    learning_enabled: true
    seed: 3103
    model_profile: "local-ops-market-observer"
    perception_streams: ["text", "events", "memory"]
    plan_scoring_enabled: true
    risk_scoring_enabled: true
    telemetry_enabled: true
    policy_fallback: "allow_non_neural"
  }

  policy {
    requires_approval: true
    risk_level: "low"
  }
}
