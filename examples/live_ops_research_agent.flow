# Live Agent Operations research workflow.
# Runs locally with tiny_torch neural-live telemetry and policy gates.
agent LiveOpsResearchAgent {
  identity: "did:flow:example:live-ops-research"
  goal: "inspect local Flow Memory state and summarize the current public-alpha run"
  autonomy: "supervised"
  tool: "respond"
  capability: "local_reasoning"
  capability: "neural_advisory"

  neural {
    enabled: true
    backend: "tiny_torch"
    live_mode: true
    learning_enabled: true
    seed: 3101
    model_profile: "local-ops-research"
    perception_streams: ["text", "events", "memory"]
    plan_scoring_enabled: true
    risk_scoring_enabled: true
    memory_retrieval_enabled: true
    telemetry_enabled: true
    policy_fallback: "allow_non_neural"
  }

  policy {
    requires_approval: true
    risk_level: "low"
  }
}
